# Bihar Transport Begusarai - Frontend Environment Variables

# API Backend URL
VITE_API_URL=http://localhost:3000/api

# Google Maps API Key (get from https://console.cloud.google.com/)
# For demo purposes without API key, the app will use fallback calculations
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# App Configuration
VITE_APP_NAME=Bihar Transport Begusarai
VITE_APP_URL=http://localhost:5173

